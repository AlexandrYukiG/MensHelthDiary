rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/entries
    // Document ID: [auto-generated]
    // Fields:
    //   - uid: string (required, immutable) - The user ID of the owner.
    //   - date: string (required) - The date of the entry.
    //   - type: string (required) - 'activity' or 'skip'.
    //   - positions: list (optional) - The positions used.
    //   - count: number (optional) - Number of times.
    //   - duration: number (optional) - Duration in minutes.
    //   - rating: number (optional) - Rating from 1 to 5.
    //   - problems: list (optional) - List of problems encountered.
    //   - notes: string (optional) - Additional notes.
    //   - skipReason: string (optional) - Reason for skipping.
    //   - skipNotes: string (optional) - Notes for skipping.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidOptionalNumber(field, min, max) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is number &&
              request.resource.data[field] >= min &&
              request.resource.data[field] <= max);
    }

    function isValidList(list, maxSize) {
      return list is list && list.size() <= maxSize;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidEntry() {
      let allowedFields = ['uid', 'date', 'type', 'positions', 'count', 'herCount', 'initiator', 'duration', 'rating', 'problems', 'toys', 'notes', 'skipReason', 'skipNotes'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['uid', 'date', 'type']) &&
             request.resource.data.uid is string && request.resource.data.uid.size() > 0 && request.resource.data.uid.size() < 100 &&
             request.resource.data.date is string && request.resource.data.date.size() > 0 && request.resource.data.date.size() < 50 &&
             request.resource.data.type in ['activity', 'skip'] &&
             (!( 'positions' in request.resource.data ) || isValidList(request.resource.data.positions, 20)) &&
             isValidOptionalNumber('count', 0, 100) &&
             isValidOptionalNumber('herCount', 0, 100) &&
             isValidOptionalString('initiator', 0, 100) &&
             isValidOptionalNumber('duration', 0, 1440) &&
             isValidOptionalNumber('rating', 1, 5) &&
             (!( 'problems' in request.resource.data ) || isValidList(request.resource.data.problems, 20)) &&
             isValidOptionalString('toys', 0, 500) &&
             isValidOptionalString('notes', 0, 2000) &&
             isValidOptionalString('skipReason', 0, 100) &&
             isValidOptionalString('skipNotes', 0, 2000);
    }

    match /users/{userId}/entries/{entryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidEntry() && uidUnchanged();
      allow update: if isOwner(userId) && isValidEntry() && uidNotModified();
      allow delete: if isOwner(userId);
    }
  }
}
